# Database Connection URL
DATABASE_URL="postgresql://user:password@host:5432/db"

# For PostgreSQL on Windows, override pg_dump path if needed
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe

# For MySQL on Windows, override mysqldump path if needed
# MYSQLDUMP_PATH=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe

# SQLite local path
# SQLITE_DB_PATH=C:\Projects\DB-Backup-Sys\data.db

# Backup configuration
BACKUP_OUTPUT_DIR=./backups
COMPRESSION=gzip

# Encryption (Phase 2)
# BACKUP_PASSPHRASE=my_secure_encryption_passphrase
# BACKUP_KEY_FILE=./backup.key

# Remote Storage Sync (S3)
# REMOTE_PROVIDER=s3
# S3_BUCKET="your-backups-bucket"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="your-aws-access-key-id"
# S3_SECRET_ACCESS_KEY="your-aws-secret-access-key"
# S3_ENDPOINT="https://your-custom-s3-endpoint.com"
# S3_KEY_PREFIX="snapshots/"
